---
import '../styles/global.css';
import { siAstro, siGithub, siCloudflareworkers } from 'simple-icons';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'TESTTITLE', description = 'TESTDESCRIPTION' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <meta name="description" content={description} />

    <title>{title}</title>

    <!-- Favicon -->
    <!-- <link rel="icon" href="/favicon.svg" /> -->

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="pt-32 min-[600px]:pb-32 transition-all duration-200">
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const host = window.location.hostname;
        document.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((a) => {
          try {
            const url = new URL(a.href);
            if (url.hostname !== host) {
              a.setAttribute('target', '_blank');
              a.setAttribute('rel', 'noreferrer');
            }
          } catch {}
        });
      });
    </script>

    <video
      autoplay
      muted
      loop
      playsinline
      poster="/bg/bg-poster.jpg"
      class="fixed top-0 left-0 w-full h-full object-cover -z-10"
    >
      <source src="/bg/bg-video.webm" type="video/webm" />
      <source src="/bg/bg-video.mp4" type="video/mp4" />
      <source src="/bg/bg-video.av1.webm" type="video/webm; codecs=av01" />
    </video>

    {/* todo: make it use more of the screen at smaller sizes */}
    <main
      class="h-auto w-[100%] min-[600px]:w-[600px] max-[999px]:mx-auto min-[999px]:ml-[200px]
      bg-slate-900/95 text-slate-200 rounded-t-2xl min-[600px]:rounded-2xl
      transition-all duration-200 ease-in-out"
    >
      <slot />

      <footer class="p-4 bg-slate-800 opacity-100 rounded-b-2xl">
        <h3 class="text-slate-50">
          <a href="https://iloveyuri.lol" class="text-slate-50 no-underline uppercase"
            >iloveyuri.lol</a
          >
          - asterisk's funny little website
        </h3>
        <p class="text-slate-50">
          Inspired by <a href="https://split.pet">split.pet</a>
          <br />
          Built with
          <a
            href="https://astro.build"
            class={'inline-flex align-bottom w-5 h-5 fill-current'}
            style={`color: ${'#' + siAstro.hex}`}
          >
            <Fragment set:html={siAstro.svg} />
          </a>
          <a href="https://astro.build" style=`color: ${'#' + siAstro.hex}`>Astro</a>
          on
          <a
            href="https://github.com/asterisk727/iloveyurilol"
            class={'inline-flex align-middle w-5 h-5 fill-slate-400'}
          >
            <Fragment set:html={siGithub.svg} />
          </a>
          <a href="https://github.com/asterisk727/iloveyurilol" class="text-slate-400">Github</a>
          and hosted with
          <a
            href="https://workers.cloudflare.com"
            class={'inline-flex align-middle w-5 h-5 fill-current'}
            style={`color: ${'#' + siCloudflareworkers.hex}`}
          >
            <Fragment set:html={siCloudflareworkers.svg} />
          </a>
          <a href="https://workers.cloudflare.com" style=`color: ${'#' + siCloudflareworkers.hex}`
            >Cloudflare Workers</a
          >
          ❤️
        </p>
      </footer>
    </main>
  </body>
</html>
