---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
---

<BaseLayout>
  <div class="p-4">
    <header>
      <hgroup>
        <h1>{frontmatter.title}</h1>
        <h3>{frontmatter.description && frontmatter.description}</h3>
        <h4>{frontmatter.date}</h4>
      </hgroup>
    </header>

    <slot />
  </div>
</BaseLayout>
