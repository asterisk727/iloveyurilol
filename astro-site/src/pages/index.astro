---
import colors from 'tailwindcss/colors';

import BaseLayout from '../layouts/BaseLayout.astro';
import FancyIcon from '@components/FancyIcon.astro';
import IconRow from '@components/IconRow.astro';
import Buttons from '@components/Buttons.astro';
import Testimonial from '@components/Testimonial.astro';
import FancySection from '@components/FancySection.astro';

import {
  siDiscord,
  siGithub,
  siLastdotfm,
  siSteam,
  siMonkeytype,
  siAstro,
  siSvelte,
  siJavascript,
  siTypescript,
  siCplusplus,
  siSqlite,
  siGit,
  siBun,
  siNodedotjs,
  siKotlin,
  siRust,
  siPython,
} from 'simple-icons';
import akashaIcon from '../assets/icons/akasha.svg?raw';

const languagesList = [
  { icon: siJavascript },
  { icon: siTypescript },
  { icon: siCplusplus },
  { icon: siSqlite, hex: '#5cb2e4' },
  { icon: siAstro },
  { icon: siSvelte },
  { icon: siGit },
];
const learningList = [
  { icon: siKotlin },
  { icon: siRust, hex: '#ffc832' },
  { icon: siPython },
  { icon: siBun, hex: '#fbf0df' },
  { icon: siNodedotjs },
];

const { title, description } = Astro.props;
---

<BaseLayout>
  <div class="pl-4 pr-4 pb-4 relative">
    <header>
      <div class="flex items-start gap-4">
        <picture class="relative -mt-16 shrink-0">
          <source srcset="pfp.png" type="img/png" />
          <img
            src="pfp.png"
            width="128"
            height="128"
            class="rounded-full border-4 border-slate-600"
            alt="asterisk's profile picture"
          />
        </picture>
        <hgroup class="pt-4">
          <div class="flex flex-wrap items-baseline gap-x-4">
            <h1>Hi, I'm Asterisk.</h1>
            <h4>a.k.a. crxmsxn</h4>
          </div>
          <h2>multifacted nerd and annoying person</h2>
        </hgroup>
      </div>
    </header>
    <FancySection title="Links to things" id="links">
      <IconRow>
        <FancyIcon
          title={siDiscord.title}
          hex={'#' + siDiscord.hex}
          url={'https://discord.com/users/616792599360962583'}
          account={'asterisk727'}
        >
          <Fragment set:html={siDiscord.svg} />
        </FancyIcon>
        <FancyIcon
          title={siGithub.title}
          hex={'#f0f6fc'}
          url={'https://github.com/asterisk727'}
          account={'asterisk727'}
        >
          <Fragment set:html={siGithub.svg} />
        </FancyIcon>
        <FancyIcon
          title={siLastdotfm.title}
          hex={'#' + siLastdotfm.hex}
          url={'https://www.last.fm/user/crxmsxn'}
          account={'crxmsxn'}
        >
          <Fragment set:html={siLastdotfm.svg} />
        </FancyIcon>
        <FancyIcon
          title={'Akasha Network'}
          hex={'#395b64'}
          url={'https://akasha.cv/profile/824368720'}
          account={'Asterisk'}
          styleID={'akasha-icon'}
        >
          <Fragment set:html={akashaIcon} />
        </FancyIcon>
        <FancyIcon
          title={'AquaDX'}
          url={'https://aquadx.net/u/crxmsxn'}
          account={'crxmsxn'}
          styleID={'aquadx-icon'}
        >
          <img src="icons/aquadx.png" />
        </FancyIcon>
        <FancyIcon
          title={siSteam.title}
          hex={'#1a9fff'}
          url={'https://steamcommunity.com/id/_asterisk_/'}
          account={'crxmsxn'}
        >
          <Fragment set:html={siSteam.svg} />
        </FancyIcon>
        <FancyIcon
          title={siMonkeytype.title}
          hex={'#' + siMonkeytype.hex}
          url={'https://monkeytype.com/profile/asterai'}
          account={'asterai'}
        >
          <Fragment set:html={siMonkeytype.svg} />
        </FancyIcon>
      </IconRow>
    </FancySection>
    <FancySection title="10% knowledge of these:" id="languages">
      <IconRow>
        {
          languagesList.map(({ icon, hex }) => (
            <FancyIcon title={icon.title} hex={hex ? hex : '#' + icon.hex}>
              <Fragment set:html={icon.svg} />
            </FancyIcon>
          ))
        }
      </IconRow>
    </FancySection>
    <FancySection title="3% knowledge of these:" subtitle="(or want to learn)" id="learning">
      <IconRow>
        {
          learningList.map(({ icon, hex }) => (
            <FancyIcon title={icon.title} hex={hex ? hex : '#' + icon.hex}>
              <Fragment set:html={icon.svg} />
            </FancyIcon>
          ))
        }
      </IconRow>
    </FancySection>
    <FancySection title="Fun things I've done" id="projects">
      <!-- something so that linter doesn't destroy the closing tag -->
    </FancySection>
    <FancySection title="Blog posts" id="blogposts">
      <!-- something so that linter doesn't destroy the closing tag -->
    </FancySection>
    <FancySection title="clicky clicky buttons" id="buttons">
      <div class="mx-auto min-[667px]:w-[80%]">
        <div class="grid grid-cols-3 min-[667px]:grid-cols-4 gap-4">
          <Buttons />
        </div>
      </div>
    </FancySection>
    <FancySection title="testimonials" id="testimonials">
      <div class="grid grid-cols-1 gap-4">
        <Testimonial
          review={{
            stars: 1,
            author: 'sabrina 🥝',
            content: 'can we kill this guy',
          }}
          ;
        />
        <Testimonial
          review={{
            stars: 1,
            author: 'MaymayDX',
            content: "you want me to kill myself don't you",
          }}
          ;
        />
        <Testimonial
          review={{
            stars: 2,
            author: 'Entrine',
            content: '[asterisk is] a walking ragebaiter ... master baiter',
          }}
          ;
        />
        <Testimonial
          review={{
            stars: 5,
            author: 'laproliliu',
            content: "don't die ... you are very cool",
          }}
          ;
        />
      </div>
    </FancySection>
    <div class="pb-4"></div>
  </div>
</BaseLayout>
